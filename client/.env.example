# ===================================
# SUPABASE CONFIGURATION
# ===================================
# Get these values from: https://supabase.com/dashboard
# 1. Create/select your project
# 2. Go to Settings → API
# 3. Copy the values below

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===================================
# INSTRUCTIONS
# ===================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Replace the values above with your Supabase credentials
#
# 3. Restart the dev server:
#    npm run dev
#
# NOTE: The ANON_KEY is safe to use in frontend code.
# It has limited permissions controlled by RLS policies.