# OpenAI API Key (obligatorio para transcribir y analizar)
OPENAI_API_KEY=sk-proj-...

# Nano Banana API Key (OPCIONAL - para generación de imágenes alternativo)
NANO_BANANA_API_KEY=your_nano_banana_api_key

# Instagram (OPCIONAL - solo necesario para analizar perfiles de Instagram)
# TikTok funciona sin configuración adicional
# Para Instagram, necesitás una cuenta (puede ser una cuenta fake)
INSTAGRAM_USER=tu_usuario_de_instagram
INSTAGRAM_PASS=tu_contraseña_de_instagram
